{
  "format": "custom",
  "id": "success_case",
  "label": "Success Case",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID (URL do Case)"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Título do Case",
          "placeholder": "Ex: Como a Escola X aumentou as matrículas em 30%",
          "allowTargetBlank": true,
          "multi": "heading1"
        }
      },
      "client_name": {
        "type": "Text",
        "config": {
          "label": "Nome do Cliente/Escola",
          "placeholder": "Ex: Colégio Progresso"
        }
      },
      "client_logo": {
        "type": "Image",
        "config": {
          "label": "Logo do Cliente",
          "constraint": {},
          "thumbnails": []
        }
      },
      "challenge": {
        "type": "StructuredText",
        "config": {
          "label": "O Desafio",
          "placeholder": "Descreva o problema que a escola enfrentava antes do Maskot",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em"
        }
      },
      "solution": {
        "type": "StructuredText",
        "config": {
          "label": "A Solução",
          "placeholder": "Como o Maskot foi utilizado para resolver o desafio",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em"
        }
      },
      "result": {
        "type": "StructuredText",
        "config": {
          "label": "O Resultado",
          "placeholder": "Os resultados gerais alcançados",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em"
        }
      },
      "metrics": {
        "type": "Group",
        "config": {
          "fields": {
            "metric_value": {
              "type": "Text",
              "config": {
                "label": "Valor da Métrica",
                "placeholder": "Ex: +30%"
              }
            },
            "metric_label": {
              "type": "Text",
              "config": {
                "label": "Rótulo da Métrica",
                "placeholder": "Ex: em novas matrículas"
              }
            }
          },
          "label": "Métricas de Destaque"
        }
      },
      "testimonial_text": {
        "type": "StructuredText",
        "config": {
          "label": "Texto do Depoimento",
          "placeholder": "Citação do cliente",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em"
        }
      },
      "testimonial_author": {
        "type": "Text",
        "config": {
          "label": "Autor do Depoimento",
          "placeholder": "Ex: João Silva, Diretor"
        }
      },
      "testimonial_avatar": {
        "type": "Image",
        "config": {
          "label": "Foto do Autor",
          "constraint": {},
          "thumbnails": []
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone (Conteúdo Adicional)",
        "config": {
          "choices": {
            "rich_text": {
              "type": "SharedSlice"
            }
          }
        }
      }
    }
  }
}
